package(default_visibility = ["//visibility:public"])

exports_files([
    "README.md",
    "forks.tsv",
])

sh_binary(
    name = "verify",
    srcs = ["verify_forks.sh"],
    data = ["forks.tsv"],
    args = ["$(location forks.tsv)"],
)

sh_test(
    name = "verify_forks_test",
    srcs = ["verify_forks_test.sh"],
    data = ["verify_forks.sh"],
)

filegroup(
    name = "package_boundary",
    srcs = [
        "README.md",
        "forks.tsv",
        "verify_forks.sh",
    ],
)
