load("@rules_rust//rust:defs.bzl", "rust_clippy", "rust_library", "rust_test", "rustfmt_test")

package(default_visibility = ["//visibility:public"])

rust_library(
    name = "slic3r_contracts",
    srcs = [
        "src/flavor.rs",
        "src/lib.rs",
    ],
    edition = "2024",
)

rust_test(
    name = "slic3r_contracts_test",
    srcs = ["tests/parse.rs"],
    deps = [":slic3r_contracts"],
    edition = "2024",
)

rust_test(
    name = "flavor_contracts_test",
    srcs = ["tests/flavor_contracts.rs"],
    deps = [":slic3r_contracts"],
    edition = "2024",
)

rust_clippy(
    name = "clippy",
    testonly = True,
    deps = [
        ":flavor_contracts_test",
        ":slic3r_contracts",
        ":slic3r_contracts_test",
    ],
)

rustfmt_test(
    name = "rustfmt_check",
    targets = [
        ":flavor_contracts_test",
        ":slic3r_contracts",
        ":slic3r_contracts_test",
    ],
)
