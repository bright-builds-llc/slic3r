package(default_visibility = ["//visibility:public"])

exports_files(["Cargo.toml"])

filegroup(
    name = "workspace_root",
    srcs = ["Cargo.toml"],
)

alias(
    name = "slic3r_core",
    actual = "//packages/slic3r-rust/crates/slic3r_core:slic3r_core",
)

alias(
    name = "slic3r_contracts",
    actual = "//packages/slic3r-rust/crates/slic3r_contracts:slic3r_contracts",
)

alias(
    name = "slic3r_cli",
    actual = "//packages/slic3r-rust/crates/slic3r_cli:slic3r_cli",
)

sh_test(
    name = "clippy_check",
    srcs = ["verify_clippy.sh"],
    data = [
        "//packages/slic3r-rust/crates/slic3r_cli:clippy",
        "//packages/slic3r-rust/crates/slic3r_contracts:clippy",
        "//packages/slic3r-rust/crates/slic3r_core:clippy",
    ],
)

test_suite(
    name = "verify",
    tests = [
        ":clippy_check",
        "//packages/slic3r-rust/crates/slic3r_cli:rustfmt_check",
        "//packages/slic3r-rust/crates/slic3r_cli:slic3r_cli_test",
        "//packages/slic3r-rust/crates/slic3r_contracts:rustfmt_check",
        "//packages/slic3r-rust/crates/slic3r_core:rustfmt_check",
        "//packages/slic3r-rust/crates/slic3r_contracts:flavor_contracts_test",
        "//packages/slic3r-rust/crates/slic3r_contracts:slic3r_contracts_test",
        "//packages/slic3r-rust/crates/slic3r_core:slic3r_core_smoke_test",
    ],
)
